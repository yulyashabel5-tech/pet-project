3\u0440\u0430 \u043f\u0440\u043e\u0435\u043a\u0442\u0430","text":"<pre><code>Pet_project/         # \u041a\u043e\u0440\u043d\u0435\u0432\u0430\u044f \u043f\u0430\u043f\u043a\u0430 \u043f\u0440\u043e\u0435\u043a\u0442\u0430\n\u251c\u2500\u2500 mkdocs.yml       # \u041a\u043e\u043d\u0444\u0438\u0433\u0443\u0440\u0430\u0446\u0438\u044f MkDocs\n\u2514\u2500\u2500 docs/            # \u0412\u0441\u0435 Markdown\u2011\u0444\u0430\u0439\u043b\u044b \u0438 \u0440\u0435\u0441\u0443\u0440\u0441\u044b\n    \u251c\u2500\u2500 index.md     # \u0413\u043b\u0430\u0432\u043d\u0430\u044f \u0441\u0442\u0440\u0430\u043d\u0438\u0446\u0430\n    \u251c\u2500\u2500 instructions.md   # \u0418\u043d\u0441\u0442\u0440\u0443\u043a\u0446\u0438\u0438\n    \u2502   \u251c\u2500\u2500 page1.md\n    \u2502   \u2514\u2500\u2500 page2.md\n    \u251c\u2500\u2500 FAQ/    # \u0412\u043e\u043f\u0440\u043e\u0441\u044b/\u041e\u0442\u0432\u0435\u0442\u044b\n    \u2502   \u251c\u2500\u2500 page3.md\n    \u2502   \u2514\u2500\u2500 page4.md\n    \u2514\u2500\u2500 images/      # \u0418\u0437\u043e\u0431\u0440\u0430\u0436\u0435\u043d\u0438\u044f\n        \u251c\u2500\u2500 logo.svg\n        \u251c\u2500\u2500 FAQ1.png\n        \u251c\u2500\u2500 FAQ2.png\n        \u2514\u2500\u2500 FAQ3.png\n</code></pre>"},{"location":"FAQ/","title":"\u041e\u0442\u0432\u0435\u0442\u044b \u043d\u0430 \u0447\u0430\u0441\u0442\u043e \u0437\u0430\u0434\u0430\u0432\u0430\u0435\u043c\u044b\u0435 \u0432\u043e\u043f\u0440\u043e\u0441\u044b","text":""},{"location":"FAQ/#_1","title":"\u041e\u0442\u0432\u0435\u0442\u044b \u043d\u0430 \u0447\u0430\u0441\u0442\u043e \u0437\u0430\u0434\u0430\u0432\u0430\u0435\u043c\u044b\u0435 \u0432\u043e\u043f\u0440\u043e\u0441\u044b","text":"<p>\u0412 \u0440\u0430\u0437\u0434\u0435\u043b\u0435 \u0441\u043e\u0431\u0440\u0430\u043d\u044b \u043e\u0442\u0432\u0435\u0442\u044b \u043d\u0430 \u0447\u0430\u0441\u0442\u044b\u0435 \u0432\u043e\u043f\u0440\u043e\u0441\u044b \u0438 \u043f\u0440\u043e\u0431\u043b\u0435\u043c\u044b, \u0432\u043e\u0437\u043d\u0438\u043a\u0430\u044e\u0449\u0438\u0435 \u0443 \u0442\u0435\u0445\u043d\u0438\u0447\u0435\u0441\u043a\u043e\u0433\u043e \u043f\u0438\u0441\u0430\u0442\u0435\u043b\u044f \u0432 \u043f\u0440\u043e\u0446\u0435\u0441\u0441\u0435 \u0440\u0430\u0431\u043e\u0442\u044b \u0441 \u0438\u043d\u0441\u0442\u0440\u0443\u043c\u0435\u043d\u0442\u0430\u043c\u0438</p>"},{"location":"FAQ/page3/","title":"\u041d\u0435 \u0430\u043a\u0442\u0438\u0432\u043d\u0430 \u043a\u043d\u043e\u043f\u043a\u0430 \u0423\u0440\u0430\u0432\u043d\u0435\u043d\u0438\u0435","text":"","tags":["help","word"]},{"location":"FAQ/page3/#word","title":"\u0412 Word \u043d\u0435 \u0430\u043a\u0442\u0438\u0432\u043d\u0430 \u043a\u043d\u043e\u043f\u043a\u0430 \u0423\u0440\u0430\u0432\u043d\u0435\u043d\u0438\u0435","text":"<ol> <li>\u041d\u0430\u0436\u043c\u0438\u0442\u0435 \u0424\u0430\u0439\u043b \u2192 \u0421\u0432\u0435\u0434\u0435\u043d\u0438\u044f. </li> </ol> <p> 2. \u041d\u0430\u0436\u043c\u0438\u0442\u0435 \u043a\u043d\u043e\u043f\u043a\u0443 \u041f\u0440\u0435\u043e\u0431\u0440\u0430\u0437\u043e\u0432\u0430\u0442\u044c \u0432 \u0440\u0430\u0437\u0434\u0435\u043b\u0435 \u0420\u0435\u0436\u0438\u043c \u0441\u043e\u0432\u043c\u0435\u0441\u0442\u0438\u043c\u043e\u0441\u0442\u0438. </p> <p> 3. \u041d\u0430\u0436\u043c\u0438\u0442\u0435 \u041e\u041a. \u0424\u0430\u0439\u043b \u0431\u0443\u0434\u0435\u0442 \u043f\u0440\u0435\u043e\u0431\u0440\u0430\u0437\u043e\u0432\u0430\u043d \u0432 \u0444\u043e\u0440\u043c\u0430\u0442 .docx.</p> <p>\u041f\u043e\u0441\u043b\u0435 \u043f\u0440\u0435\u043e\u0431\u0440\u0430\u0437\u043e\u0432\u0430\u043d\u0438\u044f \u043a\u043d\u043e\u043f\u043a\u0430 \u0423\u0440\u0430\u0432\u043d\u0435\u043d\u0438\u0435 \u0441\u0442\u0430\u043d\u0435\u0442 \u0430\u043a\u0442\u0438\u0432\u043d\u043e\u0439.</p>","tags":["help","word"]},{"location":"FAQ/page4/","title":"\u041d\u0443\u043c\u0435\u0440\u0430\u0446\u0438\u044f \u0442\u0430\u0431\u043b\u0438\u0446 \u0438 \u0440\u0438\u0441\u0443\u043d\u043a\u043e\u0432 \u0441 \u0437\u0430\u0434\u0430\u043d\u043d\u043e\u0433\u043e \u043d\u043e\u043c\u0435\u0440\u0430","text":"","tags":["help","word"]},{"location":"FAQ/page4/#_1","title":"\u041d\u0443\u043c\u0435\u0440\u0430\u0446\u0438\u044f \u0442\u0430\u0431\u043b\u0438\u0446 \u0438 \u0440\u0438\u0441\u0443\u043d\u043a\u043e\u0432 \u0441 \u0437\u0430\u0434\u0430\u043d\u043d\u043e\u0433\u043e \u043d\u043e\u043c\u0435\u0440\u0430","text":"","tags":["help","word"]},{"location":"FAQ/page4/#_2","title":"\u041d\u0443\u043c\u0435\u0440\u0430\u0446\u0438\u044f \u0441 \u043f\u0440\u043e\u0438\u0437\u0432\u043e\u043b\u044c\u043d\u043e\u0433\u043e \u043d\u043e\u043c\u0435\u0440\u0430","text":"<ol> <li> <p>\u0412\u0441\u0442\u0430\u0432\u044c\u0442\u0435 \u0441\u0442\u0430\u043d\u0434\u0430\u0440\u0442\u043d\u0443\u044e \u043f\u043e\u0434\u043f\u0438\u0441\u044c. \u0412\u0441\u0442\u0430\u0432\u044c\u0442\u0435 \u2192 \u041d\u0430\u0434\u043f\u0438\u0441\u044c \u2192 \u0422\u0430\u0431\u043b\u0438\u0446\u0430 (\u0438\u043b\u0438 \u0420\u0438\u0441\u0443\u043d\u043e\u043a). \u0412 \u0434\u043e\u043a\u0443\u043c\u0435\u043d\u0442\u0435 \u043f\u043e\u044f\u0432\u0438\u0442\u0441\u044f, \u043d\u0430\u043f\u0440\u0438\u043c\u0435\u0440, \u0422\u0430\u0431\u043b\u0438\u0446\u0430 1</p> </li> <li> <p>\u041f\u0435\u0440\u0435\u0439\u0434\u0438\u0442\u0435 \u0432 \u0440\u0435\u0436\u0438\u043c \u0440\u0435\u0434\u0430\u043a\u0442\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u044f \u043f\u043e\u043b\u044f:</p> <ul> <li> <p>\u0412\u044b\u0434\u0435\u043b\u0438\u0442\u0435 \u043d\u043e\u043c\u0435\u0440 (\u0442\u043e\u043b\u044c\u043a\u043e \u0446\u0438\u0444\u0440\u0443 1). </p> </li> <li> <p>\u041d\u0430\u0436\u043c\u0438\u0442\u0435 Shift+F9, \u0447\u0442\u043e\u0431\u044b \u043e\u0442\u043e\u0431\u0440\u0430\u0437\u0438\u0442\u044c \u043a\u043e\u0434 \u043f\u043e\u043b\u044f. \u0412\u043c\u0435\u0441\u0442\u043e \u043d\u043e\u043c\u0435\u0440\u0430 \u043f\u043e\u044f\u0432\u0438\u0442\u0441\u044f \u043a\u043e\u043d\u0441\u0442\u0440\u0443\u043a\u0446\u0438\u044f \u0432\u0438\u0434\u0430 { SEQ \u0422\u0430\u0431\u043b\u0438\u0446\u0430 * ARABIC } \u0438\u043b\u0438 \u043d\u0430\u0436\u043c\u0438\u0442\u0435 \u041b\u041a\u041c \u043d\u0430 \u043d\u043e\u043c\u0435\u0440 -&gt; \u0432\u044b\u0431\u0435\u0440\u0438 \u041a\u043e\u0434\u044b/\u0437\u043d\u0430\u0447\u0435\u043d\u0438\u044f \u043f\u043e\u043b\u0435\u0439.</p> </li> </ul> </li> <li> <p>\u0414\u043e\u0431\u0430\u0432\u044c\u0442\u0435 \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440 \\r \u0434\u043b\u044f \u0441\u0434\u0432\u0438\u0433\u0430 \u043d\u0443\u043c\u0435\u0440\u0430\u0446\u0438\u0438:</p> <ul> <li> <p>\u0418\u0437\u043c\u0435\u043d\u0438\u0442\u0435 \u043a\u043e\u0434 \u043f\u043e\u043b\u044f, \u0434\u043e\u0431\u0430\u0432\u0438\u0432 \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440 \\r N, \u0433\u0434\u0435 N \u2014 \u043d\u0443\u0436\u043d\u044b\u0439 \u043d\u0430\u0447\u0430\u043b\u044c\u043d\u044b\u0439 \u043d\u043e\u043c\u0435\u0440.</p> </li> <li> <p>\u041f\u0440\u0438\u043c\u0435\u0440: \u0414\u043b\u044f \u043d\u0430\u0447\u0430\u043b\u0430 \u043d\u0443\u043c\u0435\u0440\u0430\u0446\u0438\u0438 \u0441 24 \u043a\u043e\u0434 \u0434\u043e\u043b\u0436\u0435\u043d \u0432\u044b\u0433\u043b\u044f\u0434\u0435\u0442\u044c \u0442\u0430\u043a:</p> </li> </ul> <p>{ SEQ \u0422\u0430\u0431\u043b\u0438\u0446\u0430 * ARABIC\\r 24 }</p> <p>\u041f\u0430\u0440\u0430\u043c\u0435\u0442\u0440 \\r 24 \u043e\u0437\u043d\u0430\u0447\u0430\u0435\u0442: \u043d\u0430\u0447\u0430\u0442\u044c \u043e\u0442\u0441\u0447\u0435\u0442 \u0441 24, \u0430 \u0441\u043b\u0435\u0434\u0443\u044e\u0449\u0438\u0439 \u044d\u043b\u0435\u043c\u0435\u043d\u0442 \u0431\u0443\u0434\u0435\u0442 25.</p> </li> <li> <p>\u041e\u0431\u043d\u043e\u0432\u0438\u0442\u0435 \u043f\u043e\u043b\u0435 \u0438 \u0432\u044b\u0439\u0434\u0438\u0442\u0435 \u0438\u0437 \u0440\u0435\u0436\u0438\u043c\u0430 \u043a\u043e\u0434\u0430:</p> <ul> <li> <p>\u0429\u0435\u043b\u043a\u043d\u0438 \u0432\u043d\u0443\u0442\u0440\u0438 \u043a\u043e\u0434\u0430 \u043f\u043e\u043b\u044f \u0438 \u043d\u0430\u0436\u043c\u0438\u0442\u0435 F9 \u0434\u043b\u044f \u043e\u0431\u043d\u043e\u0432\u043b\u0435\u043d\u0438\u044f. \u041d\u043e\u043c\u0435\u0440 \u0432 \u0434\u043e\u043a\u0443\u043c\u0435\u043d\u0442\u0435 \u0438\u0437\u043c\u0435\u043d\u0438\u0442\u0441\u044f \u043d\u0430 25.</p> </li> <li> <p>\u041d\u0430\u0436\u043c\u0438\u0442\u0435 Shift+F9 \u0435\u0449\u0435 \u0440\u0430\u0437, \u0447\u0442\u043e\u0431\u044b \u0441\u043a\u0440\u044b\u0442\u044c \u043a\u043e\u0434 \u0438 \u0432\u0435\u0440\u043d\u0443\u0442\u044c\u0441\u044f \u043a \u043e\u0431\u044b\u0447\u043d\u043e\u043c\u0443 \u043e\u0442\u043e\u0431\u0440\u0430\u0436\u0435\u043d\u0438\u044e, \u0435\u0441\u043b\u0438 \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u043b\u0438 \u043d\u0430 \u0448\u0430\u0433\u0435 2 \u044d\u0442\u0443 \u043a\u043e\u043c\u0431\u0438\u043d\u0430\u0446\u0438\u044e, \u0430 \u043d\u0435 \u041b\u041a\u041c.</p> </li> </ul> </li> <li> <p>\u0421\u043b\u0435\u0434\u0443\u044e\u0449\u0430\u044f \u043f\u043e\u0434\u043f\u0438\u0441\u044c \u0431\u0443\u0434\u0435\u0442 \u043f\u0440\u043e\u043d\u0443\u043c\u0435\u0440\u043e\u0432\u0430\u043d\u0430 \u0430\u0432\u0442\u043e\u043c\u0430\u0442\u0438\u0447\u0435\u0441\u043a\u0438. \u041f\u0440\u0438 \u0432\u0441\u0442\u0430\u0432\u043a\u0435 \u0441\u043b\u0435\u0434\u0443\u044e\u0449\u0435\u0439 \u0441\u0442\u0430\u043d\u0434\u0430\u0440\u0442\u043d\u043e\u0439 \u043f\u043e\u0434\u043f\u0438\u0441\u0438 \u0422\u0430\u0431\u043b\u0438\u0446\u0430 (\u0438\u043b\u0438 \u0420\u0438\u0441\u0443\u043d\u043e\u043a) Word \u043f\u0440\u043e\u0434\u043e\u043b\u0436\u0438\u0442 \u043f\u043e\u0441\u043b\u0435\u0434\u043e\u0432\u0430\u0442\u0435\u043b\u044c\u043d\u043e\u0441\u0442\u044c \u0441 25, 26 \u0438 \u0442.\u0434.</p> </li> </ol>","tags":["help","word"]},{"location":"FAQ/page4/#_3","title":"\u0410\u0432\u0442\u043e\u043c\u0430\u0442\u0438\u0447\u0435\u0441\u043a\u0430\u044f \u043d\u0443\u043c\u0435\u0440\u0430\u0446\u0438\u044f \u0441 \u043f\u0440\u0438\u0432\u044f\u0437\u043a\u043e\u0439 \u043a \u0433\u043b\u0430\u0432\u0430\u043c","text":"<ol> <li> <p>\u0421\u043e\u0437\u0434\u0430\u0439\u0442\u0435 \u0441\u0442\u0438\u043b\u0438 \u0437\u0430\u0433\u043e\u043b\u043e\u0432\u043a\u043e\u0432 (\u043d\u0430\u043f\u0440\u0438\u043c\u0435\u0440, \u0417\u0430\u0433\u043e\u043b\u043e\u0432\u043e\u043a 1) \u0434\u043b\u044f \u0433\u043b\u0430\u0432. </p> </li> <li> <p>\u041d\u0430\u0436\u043c\u0438\u0442\u0435 \u043d\u0430 \u0440\u0438\u0441\u0443\u043d\u043e\u043a/\u0442\u0430\u0431\u043b\u0438\u0446\u0443, \u0441 \u043a\u043e\u0442\u043e\u0440\u043e\u0439 \u0431\u0443\u0434\u0435\u0442 \u043d\u0430\u0447\u0438\u043d\u0430\u0442\u044c\u0441\u044f \u043d\u0443\u043c\u0435\u0440\u0430\u0446\u0438\u044f.</p> </li> <li> <p>\u041d\u0430\u0436\u043c\u0438\u0442\u0435 \u043a\u043d\u043e\u043f\u043a\u0443 \u0412\u0441\u0442\u0430\u0432\u0438\u0442\u044c \u043d\u0430\u0437\u0432\u0430\u043d\u0438\u0435 \u0432\u043e \u0432\u043a\u043b\u0430\u0434\u043a\u0435 \u0421\u0441\u044b\u043b\u043a\u0438. </p> </li> <li> <p>\u0412 \u043e\u043a\u043d\u0435 \u041d\u0430\u0437\u0432\u0430\u043d\u0438\u0435 \u043d\u0430\u0436\u043c\u0438\u0442\u0435 \u043a\u043d\u043e\u043f\u043a\u0443 \u041d\u0443\u043c\u0435\u0440\u0430\u0446\u0438\u044f. \u043f\u043e\u0441\u0442\u0430\u0432\u044c \u0433\u0430\u043b\u043e\u0447\u043a\u0443 \u0412\u043a\u043b\u044e\u0447\u0438\u0442\u044c \u043d\u043e\u043c\u0435\u0440 \u0433\u043b\u0430\u0432\u044b -&gt; \u0432\u044b\u0431\u0435\u0440\u0438 \u0441\u0442\u0438\u043b\u044c \u0437\u0430\u0433\u043e\u043b\u043e\u0432\u043a\u0430 \u0433\u043b\u0430\u0432\u044b (\u043d\u0430\u043f\u0440\u0438\u043c\u0435\u0440, \u0417\u0430\u0433\u043e\u043b\u043e\u0432\u043e\u043a 1) \u0438 \u0440\u0430\u0437\u0434\u0435\u043b\u0438\u0442\u0435\u043b\u044c (\u0442\u043e\u0447\u043a\u0430, \u0442\u0438\u0440\u0435)</p> </li> <li> <p>\u041f\u043e\u0441\u0442\u0430\u0432\u044c\u0442\u0435 \u0433\u0430\u043b\u043e\u0447\u043a\u0443 \u0412\u043a\u043b\u044e\u0447\u0438\u0442\u044c \u043d\u043e\u043c\u0435\u0440 \u0433\u043b\u0430\u0432\u044b. </p> </li> <li> <p>\u0412\u044b\u0431\u0435\u0440\u0438\u0442\u0435 \u0441\u0442\u0438\u043b\u044c \u0437\u0430\u0433\u043e\u043b\u043e\u0432\u043a\u0430 \u0433\u043b\u0430\u0432\u044b (\u043d\u0430\u043f\u0440\u0438\u043c\u0435\u0440, \u0417\u0430\u0433\u043e\u043b\u043e\u0432\u043e\u043a 1) \u0438 \u0440\u0430\u0437\u0434\u0435\u043b\u0438\u0442\u0435\u043b\u044c (\u0442\u043e\u0447\u043a\u0430, \u0442\u0438\u0440\u0435). </p> </li> <li> <p>\u041d\u0430\u0436\u043c\u0438\u0442\u0435 \u043a\u043d\u043e\u043f\u043a\u0443 \u041e\u041a. \u041d\u043e\u043c\u0435\u0440\u0430 \u0431\u0443\u0434\u0443\u0442 \u0444\u043e\u0440\u043c\u0438\u0440\u043e\u0432\u0430\u0442\u044c\u0441\u044f \u043a\u0430\u043a \u0413\u043b\u0430\u0432\u0430.\u041d\u043e\u043c\u0435\u0440 (\u043d\u0430\u043f\u0440\u0438\u043c\u0435\u0440, 1.1, 1.2, 2.1)</p> </li> </ol> <p></p>","tags":["help","word"]},{"location":"api/redoc-api/","title":"API Specification Redoc","text":"","tags":["API"]},{"location":"api/redoc-api/#api-specification-redoc","title":"API Specification Redoc","text":"","tags":["API"]},{"location":"api/swagger-api/","title":"API Specification Swagger","text":"","tags":["API"]},{"location":"api/swagger-api/#api-specification-swagger","title":"API Specification Swagger","text":"","tags":["API"]},{"location":"examples/page2/","title":"\u0421\u0446\u0435\u043d\u0430\u0440\u0438\u0439 \u00ab\u0420\u0435\u0434\u0430\u043a\u0442\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435 \u0437\u0430\u043c\u0435\u0442\u043a\u0438\u00bb","text":""},{"location":"examples/page2/#_1","title":"\u041f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044c\u0441\u043a\u0438\u0439 \u0441\u0446\u0435\u043d\u0430\u0440\u0438\u0439 \u00ab\u0420\u0435\u0434\u0430\u043a\u0442\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435 \u0437\u0430\u043c\u0435\u0442\u043a\u0438\u00bb","text":""},{"location":"examples/page2/#_2","title":"\u0414\u0435\u0439\u0441\u0442\u0432\u0443\u044e\u0449\u0438\u0435 \u043b\u0438\u0446\u0430","text":"<ol> <li> <p>\u041f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044c.</p> </li> <li> <p>\u041f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435.</p> </li> <li> <p>\u0411\u044d\u043a.</p> </li> <li> <p>\u0411\u0430\u0437\u0430 \u0434\u0430\u043d\u043d\u044b\u0445.</p> </li> </ol>"},{"location":"examples/page2/#_3","title":"\u041f\u0440\u0435\u0434\u0432\u0430\u0440\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u0435 \u0443\u0441\u043b\u043e\u0432\u0438\u044f","text":"<ol> <li> <p>\u041f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044c \u043d\u0430\u0445\u043e\u0434\u0438\u0442\u0441\u044f \u043d\u0430 \u0433\u043b\u0430\u0432\u043d\u043e\u043c \u044d\u043a\u0440\u0430\u043d\u0435.</p> </li> <li> <p>\u0412 \u0441\u0438\u0441\u0442\u0435\u043c\u0435 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442 \u0445\u043e\u0442\u044f \u0431\u044b \u043e\u0434\u043d\u0430 \u0437\u0430\u043c\u0435\u0442\u043a\u0430, \u0441\u043e\u0437\u0434\u0430\u043d\u043d\u0430\u044f \u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u0435\u043c.</p> </li> </ol>"},{"location":"examples/page2/#_4","title":"\u0412\u044b\u0445\u043e\u0434\u043d\u044b\u0435 \u0443\u0441\u043b\u043e\u0432\u0438\u044f","text":"<p>\u0412 \u0441\u0438\u0441\u0442\u0435\u043c\u0435 \u043f\u043e\u044f\u0432\u0438\u043b\u0430\u0441\u044c \u043e\u0442\u0440\u0435\u0434\u0430\u043a\u0442\u0438\u0440\u043e\u0432\u0430\u043d\u043d\u0430\u044f \u0437\u0430\u043c\u0435\u0442\u043a\u0430 \u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044f.</p>"},{"location":"examples/page2/#_5","title":"\u041e\u0441\u043d\u043e\u0432\u043d\u043e\u0439 \u0441\u0446\u0435\u043d\u0430\u0440\u0438\u0439","text":"<ol> <li> <p>\u041f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044c \u0432\u044b\u0431\u0438\u0440\u0430\u0435\u0442 \u0437\u0430\u043c\u0435\u0442\u043a\u0443 \u0438\u0437 \u0441\u043f\u0438\u0441\u043a\u0430.</p> </li> <li> <p>\u041f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435 \u043e\u0442\u043a\u0440\u044b\u0432\u0430\u0435\u0442 \u0444\u043e\u0440\u043c\u0443 \u043f\u0440\u043e\u0441\u043c\u043e\u0442\u0440\u0430 \u0437\u0430\u043c\u0435\u0442\u043a\u0438.</p> </li> <li> <p>\u041f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044c \u043d\u0430\u0436\u0438\u043c\u0430\u0435\u0442 \u043a\u043d\u043e\u043f\u043a\u0443 \u0420\u0435\u0434\u0430\u043a\u0442\u0438\u0440\u043e\u0432\u0430\u0442\u044c.</p> </li> <li> <p>\u041f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435 \u043e\u0442\u043a\u0440\u044b\u0432\u0430\u0435\u0442 \u0444\u043e\u0440\u043c\u0443 \u0440\u0435\u0434\u0430\u043a\u0442\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u044f \u0437\u0430\u043c\u0435\u0442\u043a\u0438.</p> </li> <li> <p>\u041f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044c \u0432\u043d\u043e\u0441\u0438\u0442 \u0438\u0437\u043c\u0435\u043d\u0435\u043d\u0438\u044f \u0432 \u0442\u0435\u043a\u0441\u0442 \u0437\u0430\u043c\u0435\u0442\u043a\u0438.</p> </li> <li> <p>\u041f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044c \u043d\u0430\u0436\u0438\u043c\u0430\u0435\u0442 \u043a\u043d\u043e\u043f\u043a\u0443 \u0421\u043e\u0445\u0440\u0430\u043d\u0438\u0442\u044c.</p> </li> <li> <p>\u041f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435 \u043e\u0442\u043f\u0440\u0430\u0432\u043b\u044f\u0435\u0442 \u0437\u0430\u043f\u0440\u043e\u0441 \u0411\u044d\u043a\u0443 \u0434\u043b\u044f \u0441\u043e\u0445\u0440\u0430\u043d\u0435\u043d\u0438\u044f \u0438\u0437\u043c\u0435\u043d\u0435\u043d\u0438\u0439.</p> </li> <li> <p>\u0411\u044d\u043a \u0441\u043e\u0445\u0440\u0430\u043d\u044f\u0435\u0442 \u0438\u0437\u043c\u0435\u043d\u0435\u043d\u0438\u044f \u0432 \u0411\u0430\u0437\u0435 \u0434\u0430\u043d\u043d\u044b\u0445.</p> </li> <li> <p>\u0411\u044d\u043a \u0432\u043e\u0437\u0432\u0440\u0430\u0449\u0430\u0435\u0442 \u041f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u044e \u043e\u0442\u0432\u0435\u0442 \u043e\u0431 \u0443\u0441\u043f\u0435\u0448\u043d\u043e\u043c \u0441\u043e\u0445\u0440\u0430\u043d\u0435\u043d\u0438\u0438.</p> </li> <li> <p>\u041f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435  \u043e\u0442\u043a\u0440\u044b\u0432\u0430\u0435\u0442 \u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044e \u0433\u043b\u0430\u0432\u043d\u044b\u0439 \u044d\u043a\u0440\u0430\u043d \u0438 \u043f\u043e\u043a\u0430\u0437\u044b\u0432\u0430\u0435\u0442 \u0443\u0432\u0435\u0434\u043e\u043c\u043b\u0435\u043d\u0438\u0435 \u00ab\u0417\u0430\u043c\u0435\u0442\u043a\u0430 \u0443\u0441\u043f\u0435\u0448\u043d\u043e \u0441\u043e\u0445\u0440\u0430\u043d\u0435\u043d\u0430\u00bb.</p> </li> </ol>"},{"location":"examples/page2/#_6","title":"\u0410\u043b\u044c\u0442\u0435\u0440\u043d\u0430\u0442\u0438\u0432\u043d\u044b\u0439 \u0441\u0446\u0435\u043d\u0430\u0440\u0438\u0439","text":"<ol> <li> <p>\u041f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044c \u0432\u044b\u0431\u0438\u0440\u0430\u0435\u0442 \u0437\u0430\u043c\u0435\u0442\u043a\u0443 \u0438\u0437 \u0441\u043f\u0438\u0441\u043a\u0430.</p> </li> <li> <p>\u041f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435 \u043e\u0442\u043a\u0440\u044b\u0432\u0430\u0435\u0442 \u043e\u043a\u043d\u043e \u0441 \u0444\u043e\u0440\u043c\u043e\u0439 \u043f\u0440\u043e\u0441\u043c\u043e\u0442\u0440\u0430 \u0437\u0430\u043c\u0435\u0442\u043a\u0438.</p> </li> <li> <p>\u041f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044c \u043d\u0430\u0436\u0438\u043c\u0430\u0435\u0442 \u043a\u043d\u043e\u043f\u043a\u0443 \u0420\u0435\u0434\u0430\u043a\u0442\u0438\u0440\u043e\u0432\u0430\u0442\u044c.</p> </li> <li> <p>\u041f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435 \u043e\u0442\u043a\u0440\u044b\u0432\u0430\u0435\u0442 \u043e\u043a\u043d\u043e \u0441 \u0444\u043e\u0440\u043c\u043e\u0439 \u0440\u0435\u0434\u0430\u043a\u0442\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u044f \u0437\u0430\u043c\u0435\u0442\u043a\u0438.</p> </li> <li> <p>\u041f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044c \u0432\u043d\u043e\u0441\u0438\u0442 \u0438\u0437\u043c\u0435\u043d\u0435\u043d\u0438\u044f \u0432 \u0442\u0435\u043a\u0441\u0442 \u0437\u0430\u043c\u0435\u0442\u043a\u0438.</p> </li> <li> <p>\u041f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044c \u043d\u0430\u0436\u0438\u043c\u0430\u0435\u0442 \u043a\u043d\u043e\u043f\u043a\u0443 \u041e\u0442\u043c\u0435\u043d\u0438\u0442\u044c.</p> </li> <li> <p>\u041f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435 \u043e\u0442\u043a\u0440\u044b\u0432\u0430\u0435\u0442 \u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044e \u0433\u043b\u0430\u0432\u043d\u044b\u0439 \u044d\u043a\u0440\u0430\u043d \u0438 \u043f\u043e\u043a\u0430\u0437\u044b\u0432\u0430\u0435\u0442 \u0443\u0432\u0435\u0434\u043e\u043c\u043b\u0435\u043d\u0438\u0435 \u00ab\u0420\u0435\u0434\u0430\u043a\u0442\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435 \u0437\u0430\u043c\u0435\u0442\u043a\u0438 \u043e\u0442\u043c\u0435\u043d\u0435\u043d\u043e\u00bb.</p> </li> </ol>"},{"location":"examples/page2/#_7","title":"\u0414\u0438\u0430\u0433\u0440\u0430\u043c\u043c\u0430 \u043f\u043e\u0441\u043b\u0435\u0434\u043e\u0432\u0430\u0442\u0435\u043b\u044c\u043d\u043e\u0441\u0442\u0438","text":"<pre>d5d963971159d9a25ecbbd932cd1af819a0dec8b693d8c4a7012246744db1975ddf5a9a238deb6635f452760dbb36d42a37aafadf387c94ba34effff56426b9d</pre><pre>f92c42c611ef6fd3c4b27e3d37380c7e2db09ff1ad9f46356df238794b0db2121d2783bffb967da061757be34f8788647e239b50b7ddd7ba41d29d13d499b289</pre> \u041a\u043e\u0434 \u0434\u0438\u0430\u0433\u0440\u0430\u043c\u043c\u044b <pre><code>@startuml\nactor \u041f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044c\nparticipant \u041f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435\nparticipant \u0411\u044d\u043a\ndatabase \"\u0411\u0430\u0437\u0430 \u0434\u0430\u043d\u043d\u044b\u0445\"\n\n\u041f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044c -&gt; \u041f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435: \u0412\u044b\u0431\u0438\u0440\u0430\u0435\u0442 \u0437\u0430\u043c\u0435\u0442\u043a\u0443 \u0438\u0437 \u0441\u043f\u0438\u0441\u043a\u0430\n\u041f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044c &lt;-- \u041f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435: \u041e\u0442\u043a\u0440\u044b\u0432\u0430\u0435\u0442 \u043e\u043a\u043d\u043e \u0441 \u0444\u043e\u0440\u043c\u043e\u0439 \u043f\u0440\u043e\u0441\u043c\u043e\u0442\u0440\u0430 \u0437\u0430\u043c\u0435\u0442\u043a\u0438\n\u041f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044c -&gt; \u041f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435: \u041d\u0430\u0436\u0438\u043c\u0430\u0435\u0442 \u043a\u043d\u043e\u043f\u043a\u0443 \u00ab\u0420\u0435\u0434\u0430\u043a\u0442\u0438\u0440\u043e\u0432\u0430\u0442\u044c\u00bb\n\u041f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044c &lt;-- \u041f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435: \u041e\u0442\u043a\u0440\u044b\u0432\u0430\u0435\u0442 \u043e\u043a\u043d\u043e \u0441 \u0444\u043e\u0440\u043c\u043e\u0439 \u0440\u0435\u0434\u0430\u043a\u0442\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u044f \u0437\u0430\u043c\u0435\u0442\u043a\u0438\n\u041f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044c -&gt; \u041f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435: \u0412\u043d\u043e\u0441\u0438\u0442 \u0438\u0437\u043c\u0435\u043d\u0435\u043d\u0438\u044f \u0438 \u043d\u0430\u0436\u0438\u043c\u0430\u0435\u0442 \u043a\u043d\u043e\u043f\u043a\u0443 \u00ab\u0421\u043e\u0445\u0440\u0430\u043d\u0438\u0442\u044c\u00bb\n\u041f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435 -&gt; \u0411\u044d\u043a: \u0417\u0430\u043f\u0440\u043e\u0441 PUT /notes/{id}\n\u0411\u044d\u043a -&gt; \"\u0411\u0430\u0437\u0430 \u0434\u0430\u043d\u043d\u044b\u0445\": \u0421\u043e\u0445\u0440\u0430\u043d\u044f\u0435\u0442 \u0437\u0430\u043c\u0435\u0442\u043a\u0443\n\u0411\u044d\u043a &lt;-- \"\u0411\u0430\u0437\u0430 \u0434\u0430\u043d\u043d\u044b\u0445\": \u0417\u0430\u043c\u0435\u0442\u043a\u0430 \u0441\u043e\u0445\u0440\u0430\u043d\u0435\u043d\u0430\n\u0411\u044d\u043a --&gt; \u041f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435: \u041e\u0442\u0432\u0435\u0442 201 \u041e\u041a\n\u041f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435 -&gt; \u041f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044c: \u041e\u0442\u043a\u0440\u044b\u0432\u0430\u0435\u0442 \u0433\u043b\u0430\u0432\u043d\u044b\u0439 \u044d\u043a\u0440\u0430\u043d \u0438 \u0443\u0432\u0435\u0434\u043e\u043c\u043b\u0435\u043d\u0438\u0435\\n \u00ab\u0417\u0430\u043c\u0435\u0442\u043a\u0430 \u0443\u0441\u043f\u0435\u0448\u043d\u043e \u0441\u043e\u0445\u0440\u0430\u043d\u0435\u043d\u0430\u00bb\n\nalt \u041e\u0442\u043c\u0435\u043d\u0430 \u0440\u0435\u0434\u0430\u043a\u0442\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u044f \u0437\u0430\u043c\u0435\u0442\u043a\u0438\n\u041f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044c -&gt; \u041f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435: \u0412\u044b\u0431\u0438\u0440\u0430\u0435\u0442 \u0437\u0430\u043c\u0435\u0442\u043a\u0443 \u0438\u0437 \u0441\u043f\u0438\u0441\u043a\u0430\n\u041f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044c &lt;-- \u041f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435: \u041e\u0442\u043a\u0440\u044b\u0432\u0430\u0435\u0442 \u043e\u043a\u043d\u043e \u0441 \u0444\u043e\u0440\u043c\u043e\u0439 \u043f\u0440\u043e\u0441\u043c\u043e\u0442\u0440\u0430 \u0437\u0430\u043c\u0435\u0442\u043a\u0438\n\u041f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044c -&gt; \u041f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435: \u041d\u0430\u0436\u0438\u043c\u0430\u0435\u0442 \u043a\u043d\u043e\u043f\u043a\u0443 \u00ab\u0420\u0435\u0434\u0430\u043a\u0442\u0438\u0440\u043e\u0432\u0430\u0442\u044c\u00bb\n\u041f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044c &lt;-- \u041f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435: \u041e\u0442\u043a\u0440\u044b\u0432\u0430\u0435\u0442 \u043e\u043a\u043d\u043e \u0441 \u0444\u043e\u0440\u043c\u043e\u0439 \u0440\u0435\u0434\u0430\u043a\u0442\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u044f \u0437\u0430\u043c\u0435\u0442\u043a\u0438\n\u041f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044c -&gt; \u041f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435: \u041d\u0430\u0436\u0438\u043c\u0430\u0435\u0442 \u043a\u043d\u043e\u043f\u043a\u0443 \u00ab\u041e\u0442\u043c\u0435\u043d\u0438\u0442\u044c\u00bb\n\u041f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435 --&gt; \u041f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044c: \u041e\u0442\u043a\u0440\u044b\u0432\u0430\u0435\u0442 \u0433\u043b\u0430\u0432\u043d\u044b\u0439 \u044d\u043a\u0440\u0430\u043d \u0438 \u0443\u0432\u0435\u0434\u043e\u043c\u043b\u0435\u043d\u0438\u0435\\n \u00ab\u0420\u0435\u0434\u0430\u043a\u0442\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435 \u0437\u0430\u043c\u0435\u0442\u043a\u0438 \u043e\u0442\u043c\u0435\u043d\u0435\u043d\u043e\u00bb \nend alt\n@enduml\n</code></pre>"},{"location":"instructions/","title":"\u0412\u0441\u0435 \u0438\u043d\u0441\u0442\u0440\u0443\u043a\u0446\u0438\u0438","text":""},{"location":"instructions/#_1","title":"\u0412\u0441\u0435 \u0438\u043d\u0441\u0442\u0440\u0443\u043a\u0446\u0438\u0438","text":"<p>\u0422\u0443\u0442 \u043b\u0435\u0436\u0430\u0442 \u0432\u0441\u0435 \u0438\u043d\u0441\u0442\u0440\u0443\u043a\u0446\u0438\u0438 </p>"},{"location":"instructions/page1/","title":"\u0421\u043c\u0435\u043d\u0430 \u0430\u0432\u0430\u0442\u0430\u0440\u043a\u0438 \u0432 Telegram","text":"","tags":["help","manual"]},{"location":"instructions/page1/#telegram-android","title":"\u0421\u043c\u0435\u043d\u0430 \u0430\u0432\u0430\u0442\u0430\u0440\u043a\u0438 \u0432 Telegram \u043d\u0430 Android","text":"","tags":["help","manual"]},{"location":"instructions/page1/#1","title":"\u0421\u043f\u043e\u0441\u043e\u0431 1. \u0427\u0435\u0440\u0435\u0437 \u041d\u0430\u0441\u0442\u0440\u043e\u0439\u043a\u0438","text":"<ol> <li> <p>\u041e\u0442\u043a\u0440\u043e\u0439\u0442\u0435 Telegram.</p> </li> <li> <p>\u041d\u0430\u0436\u043c\u0438\u0442\u0435 \u041d\u0430\u0441\u0442\u0440\u043e\u0439\u043a\u0438 (\u2699\ufe0f).</p> </li> <li> <p>\u041d\u0430\u0436\u043c\u0438\u0442\u0435 \u043d\u0430 \u0442\u0435\u043a\u0443\u0449\u0443\u044e \u0430\u0432\u0430\u0442\u0430\u0440\u043a\u0443 (\u0438\u043b\u0438 \u043d\u0430 \u043f\u0443\u0441\u0442\u043e\u0435 \u043c\u0435\u0441\u0442\u043e \u0434\u043b\u044f \u0430\u0432\u0430\u0442\u0430\u0440\u043a\u0438) \u0432\u0432\u0435\u0440\u0445\u0443 \u044d\u043a\u0440\u0430\u043d\u0430.</p> </li> <li> <p>\u0412\u044b\u0431\u0435\u0440\u0438\u0442\u0435 \u0438\u0441\u0442\u043e\u0447\u043d\u0438\u043a \u0430\u0432\u0430\u0442\u0430\u0440\u043a\u0438: </p> <ul> <li> <p>\u0413\u0430\u043b\u0435\u0440\u0435\u044f \u2014 \u0433\u043e\u0442\u043e\u0432\u043e\u0435 \u0444\u043e\u0442\u043e.</p> </li> <li> <p>\u041a\u0430\u043c\u0435\u0440\u0430 \u2014 \u043d\u043e\u0432\u043e\u0435 \u0444\u043e\u0442\u043e.</p> </li> <li> <p>\u0412\u044b\u0431\u0440\u0430\u0442\u044c \u044d\u043c\u043e\u0434\u0437\u0438 \u2014 \u0430\u043d\u0438\u043c\u0438\u0440\u043e\u0432\u0430\u043d\u043d\u0430\u044f \u0430\u0432\u0430\u0442\u0430\u0440\u043a\u0430.</p> </li> </ul> </li> <li> <p>\u041e\u0431\u0440\u0435\u0436\u044c\u0442\u0435 \u0430\u0432\u0430\u0442\u0430\u0440\u043a\u0443 \u0441 \u043f\u043e\u043c\u043e\u0449\u044c\u044e \u043a\u0440\u0443\u0433\u043b\u043e\u0433\u043e \u0448\u0430\u0431\u043b\u043e\u043d\u0430. \u0410\u0432\u0430\u0442\u0430\u0440\u043a\u0443 \u043c\u043e\u0436\u043d\u043e \u043c\u0430\u0441\u0448\u0442\u0430\u0431\u0438\u0440\u043e\u0432\u0430\u0442\u044c \u0438 \u043f\u0435\u0440\u0435\u043c\u0435\u0449\u0430\u0442\u044c.</p> </li> <li> <p>\u041d\u0430\u0436\u043c\u0438\u0442\u0435 \u0413\u043e\u0442\u043e\u0432\u043e. \u0410\u0432\u0430\u0442\u0430\u0440\u043a\u0430 \u043e\u0431\u043d\u043e\u0432\u0438\u0442\u0441\u044f.</p> </li> </ol>","tags":["help","manual"]},{"location":"instructions/page1/#2","title":"\u0421\u043f\u043e\u0441\u043e\u0431 2. \u0427\u0435\u0440\u0435\u0437 \u041f\u0440\u043e\u0444\u0438\u043b\u044c","text":"<ol> <li> <p>\u041e\u0442\u043a\u0440\u043e\u0439\u0442\u0435 Telegram.</p> </li> <li> <p>\u041d\u0430\u0436\u043c\u0438\u0442\u0435 \u041f\u0440\u043e\u0444\u0438\u043b\u044c.</p> </li> <li> <p>\u041d\u0430\u0436\u043c\u0438\u0442\u0435 \u0412\u044b\u0431\u0440\u0430\u0442\u044c \u0444\u043e\u0442\u043e.</p> </li> <li> <p>\u0412\u044b\u043f\u043e\u043b\u043d\u0438\u0442\u0435 \u0448\u0430\u0433\u0438 4\u20136 \u0438\u0437 \u0441\u043f\u043e\u0441\u043e\u0431\u0430 1.</p> </li> </ol>","tags":["help","manual"]},{"location":"instructions/page2/","title":"\u041f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044c\u0441\u043a\u0438\u0439 \u0441\u0446\u0435\u043d\u0430\u0440\u0438\u0439 \u00ab\u0420\u0435\u0434\u0430\u043a\u0442\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435 \u0437\u0430\u043c\u0435\u0442\u043a\u0438\u00bb","text":""},{"location":"instructions/page2/#_1","title":"\u041f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044c\u0441\u043a\u0438\u0439 \u0441\u0446\u0435\u043d\u0430\u0440\u0438\u0439 \u00ab\u0420\u0435\u0434\u0430\u043a\u0442\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435 \u0437\u0430\u043c\u0435\u0442\u043a\u0438\u00bb","text":""},{"location":"instructions/page2/#_2","title":"\u0414\u0435\u0439\u0441\u0442\u0432\u0443\u044e\u0449\u0438\u0435 \u043b\u0438\u0446\u0430","text":"<ol> <li> <p>\u041f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044c.</p> </li> <li> <p>\u041f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435.</p> </li> <li> <p>\u0411\u044d\u043a.</p> </li> <li> <p>\u0411\u0430\u0437\u0430 \u0434\u0430\u043d\u043d\u044b\u0445.</p> </li> </ol>"},{"location":"instructions/page2/#_3","title":"\u041f\u0440\u0435\u0434\u0432\u0430\u0440\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u0435 \u0443\u0441\u043b\u043e\u0432\u0438\u044f","text":"<ol> <li> <p>\u041f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044c \u043d\u0430\u0445\u043e\u0434\u0438\u0442\u0441\u044f \u043d\u0430 \u0433\u043b\u0430\u0432\u043d\u043e\u043c \u044d\u043a\u0440\u0430\u043d\u0435.</p> </li> <li> <p>\u0412 \u0441\u0438\u0441\u0442\u0435\u043c\u0435 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442 \u0445\u043e\u0442\u044f \u0431\u044b \u043e\u0434\u043d\u0430 \u0437\u0430\u043c\u0435\u0442\u043a\u0430, \u0441\u043e\u0437\u0434\u0430\u043d\u043d\u0430\u044f \u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u0435\u043c.</p> </li> </ol>"},{"location":"instructions/page2/#_4","title":"\u0412\u044b\u0445\u043e\u0434\u043d\u044b\u0435 \u0443\u0441\u043b\u043e\u0432\u0438\u044f","text":"<p>\u0412 \u0441\u0438\u0441\u0442\u0435\u043c\u0435 \u043f\u043e\u044f\u0432\u0438\u043b\u0430\u0441\u044c \u043e\u0442\u0440\u0435\u0434\u0430\u043a\u0442\u0438\u0440\u043e\u0432\u0430\u043d\u043d\u0430\u044f \u0437\u0430\u043c\u0435\u0442\u043a\u0430 \u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044f.</p>"},{"location":"instructions/page2/#_5","title":"\u041e\u0441\u043d\u043e\u0432\u043d\u043e\u0439 \u0441\u0446\u0435\u043d\u0430\u0440\u0438\u0439","text":"<ol> <li> <p>\u041f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044c \u0432\u044b\u0431\u0438\u0440\u0430\u0435\u0442 \u0437\u0430\u043c\u0435\u0442\u043a\u0443 \u0438\u0437 \u0441\u043f\u0438\u0441\u043a\u0430.</p> </li> <li> <p>\u041f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435 \u043e\u0442\u043a\u0440\u044b\u0432\u0430\u0435\u0442 \u0444\u043e\u0440\u043c\u0443 \u043f\u0440\u043e\u0441\u043c\u043e\u0442\u0440\u0430 \u0437\u0430\u043c\u0435\u0442\u043a\u0438.</p> </li> <li> <p>\u041f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044c \u043d\u0430\u0436\u0438\u043c\u0430\u0435\u0442 \u043a\u043d\u043e\u043f\u043a\u0443 \u0420\u0435\u0434\u0430\u043a\u0442\u0438\u0440\u043e\u0432\u0430\u0442\u044c.</p> </li> <li> <p>\u041f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435 \u043e\u0442\u043a\u0440\u044b\u0432\u0430\u0435\u0442 \u0444\u043e\u0440\u043c\u0443 \u0440\u0435\u0434\u0430\u043a\u0442\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u044f \u0437\u0430\u043c\u0435\u0442\u043a\u0438.</p> </li> <li> <p>\u041f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044c \u0432\u043d\u043e\u0441\u0438\u0442 \u0438\u0437\u043c\u0435\u043d\u0435\u043d\u0438\u044f \u0432 \u0442\u0435\u043a\u0441\u0442 \u0437\u0430\u043c\u0435\u0442\u043a\u0438.</p> </li> <li> <p>\u041f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044c \u043d\u0430\u0436\u0438\u043c\u0430\u0435\u0442 \u043a\u043d\u043e\u043f\u043a\u0443 \u0421\u043e\u0445\u0440\u0430\u043d\u0438\u0442\u044c.</p> </li> <li> <p>\u041f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435 \u043e\u0442\u043f\u0440\u0430\u0432\u043b\u044f\u0435\u0442 \u0437\u0430\u043f\u0440\u043e\u0441 \u0411\u044d\u043a\u0443 \u0434\u043b\u044f \u0441\u043e\u0445\u0440\u0430\u043d\u0435\u043d\u0438\u044f \u0438\u0437\u043c\u0435\u043d\u0435\u043d\u0438\u0439.</p> </li> <li> <p>\u0411\u044d\u043a \u0441\u043e\u0445\u0440\u0430\u043d\u044f\u0435\u0442 \u0438\u0437\u043c\u0435\u043d\u0435\u043d\u0438\u044f \u0432 \u0411\u0430\u0437\u0435 \u0434\u0430\u043d\u043d\u044b\u0445.</p> </li> <li> <p>\u0411\u044d\u043a \u0432\u043e\u0437\u0432\u0440\u0430\u0449\u0430\u0435\u0442 \u041f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u044e \u043e\u0442\u0432\u0435\u0442 \u043e\u0431 \u0443\u0441\u043f\u0435\u0448\u043d\u043e\u043c \u0441\u043e\u0445\u0440\u0430\u043d\u0435\u043d\u0438\u0438.</p> </li> <li> <p>\u041f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435  \u043e\u0442\u043a\u0440\u044b\u0432\u0430\u0435\u0442 \u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044e \u0433\u043b\u0430\u0432\u043d\u044b\u0439 \u044d\u043a\u0440\u0430\u043d \u0438 \u043f\u043e\u043a\u0430\u0437\u044b\u0432\u0430\u0435\u0442 \u0443\u0432\u0435\u0434\u043e\u043c\u043b\u0435\u043d\u0438\u0435 \u00ab\u0418\u0437\u043c\u0435\u043d\u0435\u043d\u0438\u044f \u0441\u043e\u0445\u0440\u0430\u043d\u0435\u043d\u044b\u00bb.</p> </li> </ol>"},{"location":"instructions/page2/#_6","title":"\u0410\u043b\u044c\u0442\u0435\u0440\u043d\u0430\u0442\u0438\u0432\u043d\u044b\u0439 \u0441\u0446\u0435\u043d\u0430\u0440\u0438\u0439","text":"<ol> <li> <p>\u041f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044c \u0432\u044b\u0431\u0438\u0440\u0430\u0435\u0442 \u0437\u0430\u043c\u0435\u0442\u043a\u0443 \u0438\u0437 \u0441\u043f\u0438\u0441\u043a\u0430.</p> </li> <li> <p>\u041f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435 \u043e\u0442\u043a\u0440\u044b\u0432\u0430\u0435\u0442 \u043e\u043a\u043d\u043e \u0441 \u0444\u043e\u0440\u043c\u043e\u0439 \u043f\u0440\u043e\u0441\u043c\u043e\u0442\u0440\u0430 \u0437\u0430\u043c\u0435\u0442\u043a\u0438.</p> </li> <li> <p>\u041f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044c \u043d\u0430\u0436\u0438\u043c\u0430\u0435\u0442 \u043a\u043d\u043e\u043f\u043a\u0443 \u0420\u0435\u0434\u0430\u043a\u0442\u0438\u0440\u043e\u0432\u0430\u0442\u044c.</p> </li> <li> <p>\u041f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435 \u043e\u0442\u043a\u0440\u044b\u0432\u0430\u0435\u0442 \u043e\u043a\u043d\u043e \u0441 \u0444\u043e\u0440\u043c\u043e\u0439 \u0440\u0435\u0434\u0430\u043a\u0442\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u044f \u0437\u0430\u043c\u0435\u0442\u043a\u0438.</p> </li> <li> <p>\u041f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044c \u0432\u043d\u043e\u0441\u0438\u0442 \u0438\u0437\u043c\u0435\u043d\u0435\u043d\u0438\u044f \u0432 \u0442\u0435\u043a\u0441\u0442 \u0437\u0430\u043c\u0435\u0442\u043a\u0438.</p> </li> <li> <p>\u041f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044c \u043d\u0430\u0436\u0438\u043c\u0430\u0435\u0442 \u043a\u043d\u043e\u043f\u043a\u0443 \u041e\u0442\u043c\u0435\u043d\u0438\u0442\u044c.</p> </li> <li> <p>\u041f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435 \u043e\u0442\u043a\u0440\u044b\u0432\u0430\u0435\u0442 \u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044e \u0433\u043b\u0430\u0432\u043d\u044b\u0439 \u044d\u043a\u0440\u0430\u043d \u0438 \u043f\u043e\u043a\u0430\u0437\u044b\u0432\u0430\u0435\u0442 \u0443\u0432\u0435\u0434\u043e\u043c\u043b\u0435\u043d\u0438\u0435 \u00ab\u0421\u043e\u0437\u0434\u0430\u043d\u0438\u0435 \u0437\u0430\u043c\u0435\u0442\u043a\u0438 \u043e\u0442\u043c\u0435\u043d\u0435\u043d\u043e\u00bb.</p> </li> </ol>"},{"location":"instructions/page2/#_7","title":"\u0414\u0438\u0430\u0433\u0440\u0430\u043c\u043c\u0430 \u043f\u043e\u0441\u043b\u0435\u0434\u043e\u0432\u0430\u0442\u0435\u043b\u044c\u043d\u043e\u0441\u0442\u0438","text":""}]}